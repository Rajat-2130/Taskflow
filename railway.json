{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd taskflow/frontend && npm install && npm run build && cd ../backend && npm install"
  },
  "deploy": {
    "startCommand": "node taskflow/backend/server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}